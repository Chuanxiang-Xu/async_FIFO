[tasks]
pack
split
pack_cover
split_cover

[options]
multiclock on
pack: mode bmc
pack: depth 64
split: mode bmc
split: depth 64
pack_cover: mode cover
pack_cover: depth 96
split_cover: mode cover
split_cover: depth 96

[engines]
pack: smtbmc --nopresat --unroll z3
split: smtbmc --nopresat --unroll z3
pack_cover: smtbmc --nopresat --unroll z3
split_cover: smtbmc --nopresat --unroll z3

[script]
read -formal -sv fifo_mem.v
read -formal -sv wptr_full.v
read -formal -sv rptr_empty.v
read -formal -sv sync_w2r.v
read -formal -sv sync_r2w.v
read -formal -sv async_fifo_core.v
read -formal -sv async_fifo_stream.v
read -formal -sv stream_formal.sv
pack: prep -top stream_pack_formal
split: prep -top stream_split_formal
pack_cover: prep -top stream_pack_formal
split_cover: prep -top stream_split_formal

[files]
rtl/core/fifo_mem.v
rtl/core/wptr_full.v
rtl/core/rptr_empty.v
rtl/core/sync_w2r.v
rtl/core/sync_r2w.v
rtl/core/async_fifo_core.v
rtl/wrappers/async_fifo_stream.v
formal/stream_formal.sv
